{
  "name": "erp-nossozelo",
  "version": "1.0.0",
  "description": "ERP interno para gestão da empresa responsável pela operação, evolução e controle administrativo do marketplace NossoZelo.",
  "private": true,
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "next dev",
    "dev:web": "next dev",
    "dev:api": "npm run build:api && node dist-api/apps/api/src/main.js",
    "dev:all": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "build": "prisma generate && npm run build:api && next build",
    "build:web": "next build",
    "build:api": "node scripts/clean-api-build.mjs && tsc -p apps/api/tsconfig.json && node scripts/write-api-package.mjs",
    "start:api": "node dist-api/apps/api/src/main.js",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChacaraKairo/ERP-NossoZelo.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/ChacaraKairo/ERP-NossoZelo/issues"
  },
  "homepage": "https://github.com/ChacaraKairo/ERP-NossoZelo#readme",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.25.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "prisma": "^5.22.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
