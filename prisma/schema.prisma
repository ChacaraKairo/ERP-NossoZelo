generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ErpEmpresa {
  id                Int      @id @default(autoincrement())
  razaoSocial       String
  nomeFantasia      String
  cnpj              String?
  tipoEmpresa       String   @default("MEI")
  regimeTributario  String   @default("SIMEI")
  dataAbertura      DateTime?
  emailPrincipal    String?
  telefonePrincipal String?
  status            String   @default("ativa")
  criadoEm          DateTime @default(now())
  atualizadoEm      DateTime @updatedAt

  lancamentos   ErpLancamentoFinanceiro[]
  contasPagar   ErpContaPagar[]
  contasReceber ErpContaReceber[]
  servicos      ErpServicoContratado[]
  obrigacoes    ErpObrigacaoFiscal[]
  notasFiscais  ErpNotaFiscal[]
  fornecedores  ErpFornecedor[]
  fechamentos   ErpFechamentoMensal[]
  backups       ErpBackupRegistro[]
}

model ErpUsuarioInterno {
  id           Int        @id @default(autoincrement())
  nome         String
  email        String     @unique
  senhaHash    String
  perfil       String       @default("FUNDADOR")
  status       String @default("ATIVO")
  deveTrocarSenha Boolean @default(true)
  ultimoAcesso DateTime?
  criadoEm     DateTime   @default(now())
  atualizadoEm DateTime   @updatedAt

  auditorias ErpAuditoria[]
  sessoes     ErpSessao[]
}

model ErpSessao {
  id          String    @id @default(uuid())
  usuarioId   Int
  tokenHash   String    @unique
  ip          String?
  userAgent   String?
  deviceId    String?
  expiraEm    DateTime
  revogadaEm  DateTime?
  criadoEm    DateTime  @default(now())
  ultimoUsoEm DateTime?

  usuario ErpUsuarioInterno @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
  @@index([tokenHash])
  @@index([expiraEm])
}

model ErpCategoriaFinanceira {
  id           Int          @id @default(autoincrement())
  nome         String
  tipo         String
  descricao    String?
  ativo        Boolean      @default(true)
  criadoEm     DateTime     @default(now())
  atualizadoEm DateTime     @updatedAt

  lancamentos   ErpLancamentoFinanceiro[]
  contasPagar   ErpContaPagar[]
  contasReceber ErpContaReceber[]
}

model ErpLancamentoFinanceiro {
  id              Int             @id @default(autoincrement())
  empresaId       Int
  tipo            String
  categoriaId     Int
  descricao       String
  valorBruto      Decimal
  valorTaxas      Decimal         @default(0)
  valorLiquido    Decimal
  moeda           String          @default("BRL")
  cotacao         Decimal?
  dataCompetencia DateTime
  dataVencimento  DateTime?
  dataPagamento   DateTime?
  status          String @default("PENDENTE")
  formaPagamento  String?
  origem          String          @default("manual")
  referenciaTipo  String?
  referenciaId    Int?
  observacoes     String?
  criadoEm        DateTime        @default(now())
  atualizadoEm    DateTime        @updatedAt
  excluidoEm      DateTime?

  empresa   ErpEmpresa              @relation(fields: [empresaId], references: [id])
  categoria ErpCategoriaFinanceira  @relation(fields: [categoriaId], references: [id])
}

model ErpContaPagar {
  id                  Int             @id @default(autoincrement())
  empresaId           Int
  categoriaId         Int
  servicoContratadoId Int?
  descricao           String
  fornecedor          String?
  valorPrevisto       Decimal
  valorPago           Decimal?
  moeda               String          @default("BRL")
  dataVencimento      DateTime
  dataPagamento       DateTime?
  recorrente          Boolean         @default(false)
  periodicidade       String?
  status              String @default("PENDENTE")
  formaPagamento      String?
  observacoes         String?
  criadoEm            DateTime        @default(now())
  atualizadoEm        DateTime        @updatedAt
  excluidoEm          DateTime?

  empresa           ErpEmpresa             @relation(fields: [empresaId], references: [id])
  categoria         ErpCategoriaFinanceira @relation(fields: [categoriaId], references: [id])
  servicoContratado ErpServicoContratado?  @relation(fields: [servicoContratadoId], references: [id])
}

model ErpContaReceber {
  id                Int             @id @default(autoincrement())
  empresaId         Int
  categoriaId       Int
  clienteId         Int?
  prestadorId       Int?
  assinaturaId      Int?
  descricao         String
  origem            String          @default("manual")
  valorPrevisto     Decimal
  valorRecebido     Decimal?
  valorTaxas        Decimal         @default(0)
  valorLiquido      Decimal?
  dataVencimento    DateTime
  dataRecebimento   DateTime?
  status            String @default("PENDENTE")
  formaPagamento    String?
  gateway           String?
  gatewayReferencia String?
  observacoes       String?
  criadoEm          DateTime        @default(now())
  atualizadoEm      DateTime        @updatedAt
  excluidoEm        DateTime?

  empresa    ErpEmpresa              @relation(fields: [empresaId], references: [id])
  categoria  ErpCategoriaFinanceira  @relation(fields: [categoriaId], references: [id])
  cliente    MarketplaceCliente?     @relation(fields: [clienteId], references: [id])
  prestador  MarketplacePrestador?   @relation(fields: [prestadorId], references: [id])
  assinatura MarketplaceAssinatura?  @relation(fields: [assinaturaId], references: [id])
}

model ErpServicoContratado {
  id                         Int       @id @default(autoincrement())
  empresaId                  Int
  nome                       String
  fornecedor                 String
  categoria                  String
  descricao                  String?
  ambiente                   String    @default("producao")
  criticidade                String  @default("MEDIA")
  status                     String    @default("ativo")
  urlPainel                  String?
  urlSuporte                 String?
  plano                      String?
  moeda                      String    @default("BRL")
  valorEstimado              Decimal?
  valorUltimaCobranca        Decimal?
  periodicidade              String?
  dataInicio                 DateTime?
  dataRenovacao              DateTime?
  dataCancelamento           DateTime?
  metodoPagamento            String?
  responsavelInterno         String?
  possuiCredenciais          Boolean   @default(false)
  localCredenciais           String?
  ultimaRotacaoCredenciais   DateTime?
  observacoes                String?
  criadoEm                   DateTime  @default(now())
  atualizadoEm               DateTime  @updatedAt
  excluidoEm                 DateTime?

  empresa     ErpEmpresa       @relation(fields: [empresaId], references: [id])
  contasPagar ErpContaPagar[]
}

model ErpObrigacaoFiscal {
  id             Int             @id @default(autoincrement())
  empresaId      Int
  tipo           String
  ano            Int
  mes            Int?
  descricao      String?
  valor          Decimal?
  dataVencimento DateTime
  dataPagamento  DateTime?
  status         String @default("PENDENTE")
  observacoes    String?
  criadoEm       DateTime        @default(now())
  atualizadoEm   DateTime        @updatedAt
  excluidoEm     DateTime?

  empresa ErpEmpresa @relation(fields: [empresaId], references: [id])
}

model ErpNotaFiscal {
  id               Int      @id @default(autoincrement())
  empresaId        Int
  numero           String
  serie            String?
  dataEmissao      DateTime
  dataCompetencia  DateTime
  tomadorNome      String
  tomadorDocumento String?
  descricaoServico String
  valorBruto       Decimal
  status           String   @default("emitida")
  linkExterno      String?
  observacoes      String?
  criadoEm         DateTime @default(now())
  atualizadoEm     DateTime @updatedAt
  excluidoEm       DateTime?

  empresa ErpEmpresa @relation(fields: [empresaId], references: [id])
}

model ErpFechamentoMensal {
  id                    Int      @id @default(autoincrement())
  empresaId             Int
  ano                   Int
  mes                   Int
  status                String   @default("ABERTO")
  receitaTotal          Decimal  @default(0)
  despesaTotal          Decimal  @default(0)
  resultado             Decimal  @default(0)
  contasPagarAbertas    Int      @default(0)
  contasReceberAbertas  Int      @default(0)
  obrigacoesPendentes   Int      @default(0)
  notasEmitidas         Int      @default(0)
  servicosPagos         Int      @default(0)
  problemasAbertos      Int      @default(0)
  decisoesRegistradas   Int      @default(0)
  pendenciasProximoMes  Json?
  resumo                Json
  fechadoPorId          Int?
  fechadoEm             DateTime?
  criadoEm              DateTime @default(now())
  atualizadoEm          DateTime @updatedAt

  empresa ErpEmpresa @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, ano, mes])
  @@index([ano, mes])
  @@index([status])
}

model ErpBackupRegistro {
  id             Int      @id @default(autoincrement())
  empresaId      Int?
  tipo           String
  formato        String
  descricao      String?
  tamanhoBytes   Int?
  geradoPorId    Int?
  criadoEm       DateTime @default(now())

  empresa ErpEmpresa? @relation(fields: [empresaId], references: [id])

  @@index([criadoEm])
  @@index([tipo])
}

model MarketplaceCliente {
  id       Int      @id @default(autoincrement())
  nome     String
  email    String
  telefone String?
  cidade   String?
  estado   String?
  status   String   @default("ativo")
  criadoEm DateTime @default(now())

  contasReceber ErpContaReceber[]
}

model MarketplacePrestador {
  id               Int      @id @default(autoincrement())
  nome             String
  tipoPrestador    String
  email            String
  cidade           String?
  estado           String?
  statusCadastro   String   @default("pendente")
  statusAssinatura String   @default("sem_assinatura")
  documentosStatus String   @default("pendente")
  avaliacaoMedia   Decimal?
  criadoEm         DateTime @default(now())

  contasReceber ErpContaReceber[]
  assinaturas   MarketplaceAssinatura[]
}

model MarketplaceAssinatura {
  id              Int      @id @default(autoincrement())
  prestadorId     Int
  plano           String
  status          String   @default("ativa")
  valor           Decimal
  gateway         String   @default("Asaas")
  vencimento      DateTime
  ultimoPagamento DateTime?
  proximaCobranca DateTime?
  observacoes     String?
  atualizadoEm    DateTime @updatedAt

  prestador     MarketplacePrestador @relation(fields: [prestadorId], references: [id])
  contasReceber ErpContaReceber[]
}

model ErpChamado {
  id             Int      @id @default(autoincrement())
  titulo         String
  descricao      String
  tipo           String
  prioridade     String @default("MEDIA")
  status         String   @default("aberto")
  usuarioId      Int?
  prestadorId    Int?
  assinaturaId   Int?
  responsavelId  Int?
  modulo         String?
  dataAbertura   DateTime @default(now())
  dataFechamento DateTime?
  solucao        String?
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt
  excluidoEm     DateTime?

  interacoes ErpChamadoInteracao[]
}

model ErpChamadoInteracao {
  id        Int      @id @default(autoincrement())
  chamadoId Int
  autorId   Int?
  tipoAutor String   @default("interno")
  mensagem  String
  interno   Boolean  @default(true)
  criadoEm  DateTime @default(now())

  chamado ErpChamado @relation(fields: [chamadoId], references: [id])
}

model ErpTarefa {
  id                  Int        @id @default(autoincrement())
  titulo              String
  descricao           String?
  tipo                String
  prioridade          String   @default("MEDIA")
  status              String @default("PENDENTE")
  modulo              String?
  responsavelId       Int?
  dataLimite          DateTime?
  dataConclusao       DateTime?
  chamadoId           Int?
  servicoContratadoId Int?
  origem              String?
  criadoEm            DateTime   @default(now())
  atualizadoEm        DateTime   @updatedAt
  excluidoEm          DateTime?
}

model ErpFornecedor {
  id           Int      @id @default(autoincrement())
  empresaId    Int
  nome         String
  documento    String?
  email        String?
  telefone     String?
  categoria    String?
  status       String   @default("ativo")
  observacoes  String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  excluidoEm   DateTime?

  empresa ErpEmpresa @relation(fields: [empresaId], references: [id])
}

model ErpRisco {
  id           Int      @id @default(autoincrement())
  titulo       String
  descricao    String?
  modulo       String?
  probabilidade String  @default("MEDIA")
  impacto      String   @default("MEDIA")
  severidade   String   @default("MEDIA")
  status       String   @default("aberto")
  responsavel  String?
  mitigacao    String?
  dataLimite   DateTime?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  excluidoEm   DateTime?
}

model ErpDecisao {
  id           Int      @id @default(autoincrement())
  titulo       String
  contexto     String?
  decisao      String
  modulo       String?
  responsavel  String?
  dataDecisao  DateTime @default(now())
  consequencias String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  excluidoEm   DateTime?
}

model ErpBaseConhecimento {
  id           Int      @id @default(autoincrement())
  titulo       String
  conteudo     String
  categoria    String?
  tags         String?
  status       String   @default("publicado")
  criadoPor    Int?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  excluidoEm   DateTime?
}

model ErpAnexo {
  id             Int      @id @default(autoincrement())
  nomeOriginal   String
  nomeArmazenado String
  bucket         String
  objectKey      String
  mimeType       String
  tamanhoBytes   Int
  publico        Boolean  @default(false)
  referenciaTipo String?
  referenciaId   Int?
  criadoPor      Int?
  criadoEm       DateTime @default(now())
  excluidoEm     DateTime?
}

model ErpAuditoria {
  id              Int      @id @default(autoincrement())
  requestId       String?
  sessionId       String?
  deviceId        String?
  usuarioId       Int?
  acao            String
  modulo          String?
  entidadeTipo    String
  entidadeId      Int?
  metodoHttp      String?
  rota            String?
  dadosAnteriores Json?
  dadosNovos      Json?
  diff            Json?
  motivo          String?
  resultado       String   @default("sucesso")
  severidade      String   @default("INFO")
  ip              String?
  userAgent       String?
  criadoEm        DateTime @default(now())

  usuario ErpUsuarioInterno? @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
  @@index([entidadeTipo, entidadeId])
  @@index([acao])
  @@index([criadoEm])
  @@index([requestId])
}
